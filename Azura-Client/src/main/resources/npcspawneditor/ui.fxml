<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.ChoiceBox?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="385.0" prefWidth="279.0" xmlns="http://javafx.com/javafx/15.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.necrotic.client.jfx.npcspawneditor.controllers.MainController">
    <children>
        <VBox layoutX="68.0" layoutY="14.0" prefHeight="174.0" prefWidth="144.0" spacing="1.0">
            <children>
                <TextField fx:id="idField" promptText="Npc Id" />
                <ChoiceBox fx:id="directionChoiceBox" prefWidth="150.0" />
                <CheckBox fx:id="coordinateCheckBox" mnemonicParsing="false" prefHeight="17.0" prefWidth="85.0" text="Coordinate" />
                <TextField fx:id="radiusField" promptText="Radius" />
                <Button fx:id="saveButton" mnemonicParsing="false" prefHeight="25.0" prefWidth="155.0" text="Save npc spawn" />
                <TextField fx:id="formatField" promptText="Format" />
                <TextField fx:id="positionField" promptText="X, Y, Z Position" />
            </children>
        </VBox>
        <CheckBox fx:id="editingCheckBox" mnemonicParsing="false" prefHeight="17.0" prefWidth="59.0" selected="true" text="Editing" />
    </children>
</AnchorPane>
